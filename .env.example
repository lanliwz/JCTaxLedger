# Copy this file to .env and fill in local secrets before running the app.
#
#   cp .env.example .env
#   source bin/jctaxledger-env.sh

# Required for ETL, ledger verification, diffs, and local reports.
Neo4jFinDBUrl=bolt://localhost:7687
Neo4jFinDBUserName=neo4j
Neo4jFinDBPassword=change-me
Neo4jFinDBName=taxjc

# Optional aliases used by the balance report helper.
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=change-me

# Optional SMTP configuration for `bin/jctaxledger-balance-report.sh --send`.
# If SMTP is not configured on macOS, the report script can fall back to Mail.app.
# JCTAX_SMTP_HOST=smtp.example.com
# JCTAX_SMTP_PORT=587
# JCTAX_SMTP_USERNAME=you@example.com
# JCTAX_SMTP_PASSWORD=app-password
# JCTAX_REPORT_FROM_EMAIL=you@example.com
# JCTAX_SMTP_USE_TLS=true
